{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/ai-chatbot", "has": [{ "type": "host", "value": "^(www\\.)?wearevectis\\.com$" }], "destination": "https://www.aichatbot.wearevectis.com/", "permanent": true },
    { "source": "/ai-chatbot/:path*", "has": [{ "type": "host", "value": "^(www\\.)?wearevectis\\.com$" }], "destination": "https://www.aichatbot.wearevectis.com/:path*", "permanent": true },
    { "source": "/chatbot", "has": [{ "type": "host", "value": "^(www\\.)?wearevectis\\.com$" }], "destination": "https://www.aichatbot.wearevectis.com/", "permanent": true },
    { "source": "/chatbot/:path*", "has": [{ "type": "host", "value": "^(www\\.)?wearevectis\\.com$" }], "destination": "https://www.aichatbot.wearevectis.com/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!api/|_vercel/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/assets/i18n/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/assets/chatbot/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/(.*)\\.(woff2|woff|ttf|otf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(sitemap.xml|robots.txt|llms.txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
